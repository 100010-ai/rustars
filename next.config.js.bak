/** @type {import('next').NextConfig} */
const nextConfig = {
  serverExternalPackages: [
    'puppeteer',
    'puppeteer-extra',
    'puppeteer-extra-plugin-stealth',
    '@ton/ton',
    '@ton/core',
    '@ton/crypto',
  ],
  webpack: (config, { isServer }) => {
    if (isServer) {
      config.externals = config.externals || [];
      config.externals.push(
        'puppeteer',
        'puppeteer-extra',
        'puppeteer-extra-plugin-stealth',
        'clone-deep',
        'merge-deep',
      );
    }
    return config;
  },
};

module.exports = nextConfig;
