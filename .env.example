# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Telegram Bot
NEXT_PUBLIC_BOT_USERNAME=RuStarAppbot
TELEGRAM_MINIAPP_BOT_TOKEN=your_bot_token_here
ADMIN_BOT_TOKEN=your_admin_bot_token_here
ADMIN_CHAT_ID=-your_chat_id

# Support Bot
SUPPORT_BOT_TOKEN=your_support_bot_token_here

# App URL
APP_URL=https://rustars.vercel.app

# YooKassa
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# TON Wallet
MY_WALLET_MNEMONIC=your 24 word mnemonic here
MY_WALLET_ADDRESS=your_ton_wallet_address
TONCENTER_API_KEY=your_toncenter_api_key

# OneMoment Exchange
ONEMOMENT_PARTNER_KEY=your_onemoment_key

# Security
ADMIN_SECRET=generate_random_secret_here
TELEGRAM_WEBHOOK_SECRET=generate_random_secret_here
CRON_SECRET=generate_random_secret_here

# Stars Gateway
STARS_GATEWAY_URL=https://api.tonstarsgateway.com/v1
CRYPTO_SHUTTLE_API_KEY=your_gateway_key
